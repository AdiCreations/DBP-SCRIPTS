local function inspectWildPetForShiny(battle)
    if not (battle and battle.camp2 and battle.camp2.slots) then return false, false, 1 end
    for slotIndex, slot in pairs(battle.camp2.slots) do
        if typeof(slot) == "table" then
            local pet = slot.pet or slot.creature or slot.unit
            if typeof(pet) == "table" then
                local shiny = (typeof(pet.shinyTypeId) == "number" and pet.shinyTypeId > 1) or pet.isShiny == true
                local prismatic = typeof(pet.colorful) == "table" or pet.isPrismatic == true
                if shiny or prismatic then
                    -- Target is the SLOT's .pos field (confirmed live), not the table key.
                    local pos = (typeof(slot.pos) == "number" and slot.pos)
                              or (typeof(slotIndex) == "number" and slotIndex) or 1
                    return shiny, prismatic, pos
                end
            end
        end
    end
    return false, false, 1
end

local function readShinyPityText()
    local ok, pg = pcall(function() return player:FindFirstChild("PlayerGui") end)
    if not ok or not pg then return nil end
    local s = pg:FindFirstChild("ShinyPityText", true)
    return s and s.Text or nil
end

-- The "--" indicator reliably flags a real shiny, BUT it lingers for a few battles after a
-- catch. So we only trust a FRESH transition into "--", latched to the battle uid where it
-- happened. Lingering "--" in later (different-uid) battles is ignored — no wasted balls.
task.spawn(function()
    local prev = readShinyPityText()
    while _G.EvomonFarmSession == mySession do
        task.wait(0.2)
        local cur = readShinyPityText()
        if cur == "--" and prev ~= "--" then
            local b = BattleService.getCurrentBattle()
            if b then shinyBattleUid = b.uid end
        end
        prev = cur
    end
end)

local function isFreshScreenShiny(battle)
    if not battle or shinyBattleUid ~= battle.uid then return false end
    return readShinyPityText() == "--"
end

local function handleCatchCycle(battle, isAutoMode, allowFlee)
    if not battle then return end

    local isShiny, isPrismatic, targetPos = inspectWildPetForShiny(battle)
    -- Screen signal: only a FRESH "--" transition latched to THIS battle counts — that kills
    -- the lingering false positives, but still catches shinies the data flag misses.
    local screenShiny = isFreshScreenShiny(battle)
    local isTargetShinyPrismatic = isShiny or isPrismatic or screenShiny

    -- Confirmed shiny: don't pause, don't let it get attacked, catch it.
    if isShiny or isPrismatic or screenShiny then
        StatusText.Text = "Status: SHINY DETECTED — catching"
        StatusIndicator.BackgroundColor3 = C.danger
        pcall(function() BattleService.autoBattle(false) end)
    end

    if lastBattleUid ~= battle.uid then
        if isShiny or screenShiny then
            stats.shinyEncounters = stats.shinyEncounters + 1; shinyVal.Text = tostring(stats.shinyEncounters)
            addLog("Shiny encountered! Slot " .. tostring(targetPos))
        end
        if isPrismatic then
            stats.prismaticEncounters = stats.prismaticEncounters + 1; prismVal.Text = tostring(stats.prismaticEncounters)
            addLog("Prismatic encountered! Slot " .. tostring(targetPos))
        end
        lastBattleUid = battle.uid; lastCatchTime = 0; lastSkipTime = 0
    end

    if isAutoMode and _G.EvomonOnlyCatchShinyPrismatic and not isTargetShinyPrismatic then isAutoMode = false end
    if not isAutoMode and _G.EvomonAutoCatchShiny and isTargetShinyPrismatic then isAutoMode = true end

    if not isAutoMode and _G.EvomonSafeCheckMode and _G.EvomonOnlyCatchShinyPrismatic then
        StatusText.Text = "Status: Safe Verification…"; StatusIndicator.BackgroundColor3 = C.accent2
        task.wait(0.35)
        local vb = BattleService.getCurrentBattle() or battle
        local vShiny, vPrismatic, vPos = inspectWildPetForShiny(vb)
        if vShiny or vPrismatic then
            isAutoMode = true; isTargetShinyPrismatic = true
            isShiny = isShiny or vShiny; isPrismatic = isPrismatic or vPrismatic; targetPos = vPos
            addLog("SAFE CHECK: " .. (vPrismatic and "Prismatic" or "Shiny") .. " verified.")
        end
    end

    local now = tick()
    if isAutoMode then if now - lastCatchTime < 2.0 then return end
    else if now - lastSkipTime < 0.2 then return end end

    local mainBattleWindowController = ControllerManager.getController("MainBattleWindowController")

    if isAutoMode then
        StatusText.Text = "Status: Waiting for choreography…"; StatusIndicator.BackgroundColor3 = C.warn
        local ws = tick()
        while (BattleChoreoQueueModule.isStepProcessing() or BattleChoreoQueueModule.getPendingStepCount() > 0) and tick() - ws < 2.0 do task.wait(0.05) end
        local cb = BattleService.getCurrentBattle()
        if cb and cb.status == 7 then
            -- Re-read target from FRESH data right before throwing (kills stale-snapshot mis-throws).
            local fShiny, fPrism, fPos = inspectWildPetForShiny(cb)
            local pos = fPos or targetPos or 1
            if fPrism then isPrismatic = true end
            local captureCard, catchLabel
            if isPrismatic then captureCard = _G.EvomonPrismaticBall or 2000018; catchLabel = "Status: CATCHING PRISMATIC!"
            elseif isTargetShinyPrismatic then captureCard = _G.EvomonShinyBall or 2000016; catchLabel = "Status: CATCHING SHINY!"
            else captureCard = _G.EvomonNormalBall or 2000015; catchLabel = "Status: Throwing Catch Card" end
            lastCatchTime = tick(); StatusText.Text = catchLabel; StatusIndicator.BackgroundColor3 = C.accent
            -- Game's own catch (correct target) first, remote as backup.
            if mainBattleWindowController and typeof(mainBattleWindowController.applyCatchPetWithResult) == "function" then
                pcall(function() mainBattleWindowController.applyCatchPetWithResult(pos, captureCard) end)
            end
            pcall(function() performCatch(captureCard, pos) end)
            local catchUid = cb.uid
            task.spawn(function()
                task.wait(1.0)
                local c2 = BattleService.getCurrentBattle()
                if c2 and c2.uid == catchUid and c2.status == 7 then pcall(function() performCatch(captureCard, pos) end) end
            end)
        end
    else
        if not allowFlee then return end
        StatusText.Text = "Status: Skipping Catch (Fleeing)"; StatusIndicator.BackgroundColor3 = C.warn
        local cb = BattleService.getCurrentBattle()
        if cb and cb.status == 7 then
            lastSkipTime = tick()
            if mainBattleWindowController then pcall(function() mainBattleWindowController.applyGiveUpCatch() end)
            else
                simulateKeyPress(Enum.KeyCode.C)
                local st = tick()
                while tick() - st < 2.5 do local b = BattleService.getCurrentBattle(); if not b or b.status ~= 7 then break end; task.wait(0.15) end
                local c2 = BattleService.getCurrentBattle()
                if c2 and c2.status == 7 then pcall(function() ReqOperateBattle:InvokeServer({ actionType=8 }) end) end
            end
        end
    end
end

-- BATTLE MANAGER
local function manageBattle()
    StatusText.Text = "Status: Battle Active"; StatusIndicator.BackgroundColor3 = C.good
    local startT = tick()
    local autoBattleSent = false
    while (_G.EvomonFarmEnabled or _G.EvomonBossFarmEnabled) and isInBattle() and tick() - startT < 120 do
        local battle = BattleService.getCurrentBattle()
        if battle then
            local status = battle.status
            if status == 1 or status == 2 or status == 3 or status == 4 then
                pcall(function()
                    local petWinCtrl = ControllerManager.getController("BattlePetWindowController")
                    if petWinCtrl then
                        if typeof(petWinCtrl.onConfirmButtonClick) == "function" then petWinCtrl.onConfirmButtonClick()
                        elseif typeof(petWinCtrl.confirmSelectPet) == "function" then petWinCtrl.confirmSelectPet() end
                    end
                end)
                pcall(function()
                    local VIM = game:GetService("VirtualInputManager")
                    VIM:SendKeyEvent(true,Enum.KeyCode.Return,false,game); task.wait(0.02); VIM:SendKeyEvent(false,Enum.KeyCode.Return,false,game)
                    VIM:SendKeyEvent(true,Enum.KeyCode.Space,false,game); task.wait(0.02); VIM:SendKeyEvent(false,Enum.KeyCode.Space,false,game)
                end)
                if _G.NR_petUID then
                    pcall(function()
                        local c1 = BindableBattle:FindFirstChild("ClientSelectNpcBattleFirstcall")
                        local c2 = BindableBattle:FindFirstChild("ClientSelectBossBattleFirstcall")
                        local c3 = BindableBattle:FindFirstChild("ClientBossBattleSelectLeadComplete")
                        if c1 then c1:Fire(_G.NR_petUID) end
                        if c2 then c2:Fire(_G.NR_petUID) end
                        if c3 then c3:Fire(_G.NR_petUID) end
                    end)
                    pcall(function() ReqSetMainPet:InvokeServer(_G.NR_petUID) end)
                    pcall(function() ReqOperateBattle:InvokeServer({ actionType=1, petUid=_G.NR_petUID }) end)
                end
            end
            if status == 7 then pcall(function() handleCatchCycle(battle, _G.EvomonAutoCatch, true) end)
            elseif status == 9 then break
            elseif status == 2 then
                if not autoBattleSent and not (BattleChoreoQueueModule.isStepProcessing() or BattleChoreoQueueModule.getPendingStepCount() > 0) then
                    syncInGameAutoAndSpeed(); pcall(function() ReqAutoBattle:InvokeServer(true) end); autoBattleSent = true
                end
            end
        end
        task.wait(0.15)
    end
    stats.battlesWon = stats.battlesWon + 1; winsVal.Text = tostring(stats.battlesWon)
    StatusText.Text = "Status: Battle Complete"; StatusIndicator.BackgroundColor3 = C.good
end

