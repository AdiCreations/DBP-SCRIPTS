local function releasePets(onlyNew)
    local minGrade = _G.EvomonMinSellGrade or "None"
    if minGrade == "None" then return end
    local grades = { D=1, C=2, B=3, A=4, S=5, SSS=6 }
    local minRank = grades[minGrade] or 0
    if minRank == 0 then return end

    local ok1, PetStorage      = pcall(function() return require(ReplicatedStorage:WaitForChild("Storage"):WaitForChild("PetStorage")) end)
    local ok2, PetGroupStorage = pcall(function() return require(ReplicatedStorage:WaitForChild("Storage"):WaitForChild("PetGroupStorage")) end)
    if not (ok1 and ok2) then return end

    local equipped = {}
    local g2 = PetGroupStorage.getPetGroup()
    if g2 and g2.petGroupList then
        for _, g in pairs(g2.petGroupList) do
            for _, uuid in ipairs(g.petUuids or {}) do equipped[uuid] = true end
        end
    end

    local toSell = {}
    for uuid, pet in pairs(PetStorage.getPetList() or {}) do
        if not onlyNew or not (_G.EvomonPreSnapshot and _G.EvomonPreSnapshot[uuid]) then
            if not equipped[uuid] and not pet.locked and not pet.loved then
                local talent = ConfigDataManager.getConfig(ConfigConst.ConfigName.PET_TALENT, pet.talentId or 1)
                if (grades[talent and talent.des or "D"] or 1) < minRank then
                    local config = ConfigDataManager.getConfig(ConfigConst.ConfigName.PET, pet.configId)
                    if config and config.isCanRelease == true then table.insert(toSell, uuid) end
                end
            end
        end
    end

    if #toSell > 0 then
        local success, result = pcall(function() return ReplicatedStorage.Remote.Pet.ReqRemovePets:InvokeServer(toSell) end)
        if success and (result == 20000 or result == ErrorCode.SUCCEEDED) then
            stats.petsSold = stats.petsSold + #toSell
        end
    end
end

local function getNearestWildCreature()
    local char = player.Character
    local hrp  = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end
    local myPos = hrp.Position
    local status, list = CreatureSceneStorage.getCreatureListByType(3)
    if status ~= ErrorCode.SUCCEEDED or not list then return nil end
    local nearest, minDist = nil, math.huge
    for uid, creature in pairs(list) do
        if not creature.isCombating and creature.aliveState == 1 then
            local cf = creature.pos
            local pos = typeof(cf) == "CFrame" and cf.Position or (typeof(cf) == "Vector3" and cf or nil)
            if pos then
                local dist = (myPos - pos).Magnitude
                if dist < minDist and dist <= _G.EvomonFarmRadius then
                    minDist = dist
                    nearest = { uid=uid, pos=pos, level=creature.level or 0, shinyTypeId=creature.shinyTypeId }
                end
            end
        end
    end
    return nearest
end

-- PERF: cache getgc-found references so the heap is walked at most once.
local _gcCache = { prefs=nil, speedState=nil, speedButton=nil }
local function syncInGameAutoAndSpeed()
    pcall(function()
        local c = _gcCache
        if not (c.prefs and c.speedState and c.speedButton) then
            for _, v in pairs(getgc(true)) do
                if typeof(v) == "table" then
                    if not c.prefs       and rawget(v, "sessionPrefs")       then c.prefs = v.sessionPrefs end
                    if not c.speedState  and rawget(v, "battleSpeedEnabled") ~= nil then c.speedState = v end
                    if not c.speedButton and rawget(v, "_speedEnabled")      ~= nil then c.speedButton = v end
                    if c.prefs and c.speedState and c.speedButton then break end
                end
            end
        end
        if c.prefs then
            if _G.EvomonAutoInGameSpeed      then c.prefs.preferBattleSpeed = true end
            if _G.EvomonAutoInGameAutoBattle then c.prefs.preferAutoBattle  = true end
        end
        if c.speedState then
            if _G.EvomonAutoInGameSpeed      then c.speedState.battleSpeedEnabled = true end
            if _G.EvomonAutoInGameAutoBattle then c.speedState.autoBattleEnabled  = true end
        end
        if c.speedButton and isInBattle() then
            if _G.EvomonAutoInGameSpeed and not c.speedButton._speedEnabled then
                pcall(function() c.speedButton._speedEnabled = true; c.speedButton:setSpeedButton(true) end)
            end
            if _G.EvomonAutoInGameAutoBattle and not c.speedButton._autoEnabled then
                pcall(function() c.speedButton._autoEnabled = true; c.speedButton:setAutoButton(true) end)
            end
        end
        if isInBattle() and _G.EvomonAutoInGameAutoBattle then
            pcall(function() BattleService.autoBattle(true) end)
        end
    end)
end

-- ─── Client-Side Speedups ──────────────────────────────────────────────────
local function applyClientHacks()
    pcall(function()
        local BattleConst       = require(ReplicatedStorage:WaitForChild("Script"):WaitForChild("Battle"):WaitForChild("Basic"):WaitForChild("BattleConst"))
        local BattleChoreoConst = require(ReplicatedStorage:WaitForChild("Script"):WaitForChild("BattleChoreo"):WaitForChild("Basic"):WaitForChild("BattleChoreoConst"))
        BattleChoreoConst.DefaultActionWaitTime = 0.01
        BattleChoreoConst.ActionWaitTimeByType[BattleConst.ACTION_TYPE.SKILL]      = 0.01
        BattleChoreoConst.ActionWaitTimeByType[BattleConst.ACTION_TYPE.SWITCH_PET] = 0.01
        if BattleConst.ACTION_TYPE.USE_ITEM then
            BattleChoreoConst.ActionWaitTimeByType[BattleConst.ACTION_TYPE.USE_ITEM] = 0.01
        end
        BattleChoreoConst.SettleNodeWaitTime = 0.01
        for k in pairs(BattleChoreoConst.SettleNodeWaitTimeByType) do BattleChoreoConst.SettleNodeWaitTimeByType[k] = 0.01 end
        BattleChoreoConst.StartBattleBeforeChoreographyDelayTime             = 0.01
        BattleChoreoConst.FirstRoundEmptyActionResultsAnimationCompleteDelay = 0.01
        BattleChoreoConst.ForceSwitchAnimationCompleteDelay                  = 0.01
        BattleChoreoConst.OpeningThrowBallPreDelay                           = 0.01
        BattleChoreoConst.OpeningThrowBallPostDelay                          = 0.01
    end)
    pcall(function()
        local ok, SkillPerformanceCfg = pcall(function() return require(ReplicatedStorage:WaitForChild("Script"):WaitForChild("Pet"):WaitForChild("Cfg"):WaitForChild("SkillPerformanceCfg")) end)
        if ok and type(SkillPerformanceCfg) == "table" then
            for _, entry in pairs(SkillPerformanceCfg) do
                if type(entry) == "table" and type(entry.finishWaitTime) == "number" then entry.finishWaitTime = 0 end
            end
        end
    end)
    pcall(function()
        local Reporter = require(ReplicatedStorage:WaitForChild("Script"):WaitForChild("BattleChoreo"):WaitForChild("ChoreoTool"):WaitForChild("BattleChoreoAnimationCompleteReporterModule"))
        if not Reporter._isHooked then
            Reporter._isHooked = true
            local oldBegin = Reporter.beginExpectation
            Reporter.beginExpectation = function(self, p4, p5)
                oldBegin(self, p4, p5)
                task.spawn(function()
                    task.wait(0.01)
                    if _G.EvomonSpeedupEnabled then Reporter:reportComplete(p4, p5, "speedup_reporter") end
                end)
            end
        end
    end)
    pcall(function()
        local catchController = ControllerManager.getController("BattleCatchPetWindowController")
        if catchController and not catchController._catchHookApplied then
            catchController._catchHookApplied = true
            local origStartCatchAnim = catchController.startCatchAnim
            catchController.startCatchAnim = function(self, u191, p192)
                local battleData, callback
                if self == catchController then battleData, callback = u191, p192 else battleData, callback = self, u191 end
                local success = false
                if typeof(battleData) == "table" and typeof(battleData.actionResults) == "table" then
                    for i = #battleData.actionResults, 1, -1 do
                        local v = battleData.actionResults[i]
                        if typeof(v) == "table" and typeof(v.catchInfo) == "table" then
                            success = typeof(v.catchInfo.failIndex) ~= "number"; break
                        end
                    end
                end
                if success then
                    pcall(function() catchController:finishCatchPetResultUi(battleData) end)
                    if typeof(callback) == "function" then callback() end
                else
                    task.spawn(function()
                        task.wait(2.2)
                        if typeof(origStartCatchAnim) == "function" then origStartCatchAnim(self, u191, p192)
                        elseif typeof(callback) == "function" then callback() end
                    end)
                end
            end
        end
    end)
end
task.spawn(function() task.wait(2); if _G.EvomonFarmSession == mySession then pcall(applyClientHacks) end end)

