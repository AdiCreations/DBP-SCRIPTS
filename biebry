local function createToggle(parent, labelText, globalName, callback)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, -4, 0, 42)
    frame.BackgroundColor3 = C.panel
    frame.Parent = parent
    uicorner(frame, 8); uistroke(frame, C.stroke)

    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(0.74, 0, 1, 0)
    label.Position = UDim2.new(0.04, 0, 0, 0)
    label.BackgroundTransparency = 1
    label.Text = labelText
    label.TextColor3 = C.textHi
    label.TextSize = 12
    label.Font = Enum.Font.GothamBold
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = frame

    local track = Instance.new("TextButton")
    track.Size = UDim2.new(0, 46, 0, 22)
    track.Position = UDim2.new(1, -56, 0.5, -11)
    track.Text = ""
    track.AutoButtonColor = false
    track.Parent = frame
    uicorner(track, 11); uistroke(track, C.stroke)

    local circle = Instance.new("Frame")
    circle.Size = UDim2.new(0, 18, 0, 18)
    circle.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    circle.Parent = track
    uicorner(circle, 9)

    local function applyVisual(v, animate)
        local col = v and C.accent or C.toggleOff
        local pos = v and UDim2.new(1, -20, 0.5, -9) or UDim2.new(0, 2, 0.5, -9)
        if animate then
            TweenService:Create(track, TweenInfo.new(0.18, Enum.EasingStyle.Quad), {BackgroundColor3 = col}):Play()
            TweenService:Create(circle, TweenInfo.new(0.18, Enum.EasingStyle.Quad), {Position = pos}):Play()
        else
            track.BackgroundColor3 = col; circle.Position = pos
        end
    end

    local state = _G[globalName] and true or false
    applyVisual(state, false)
    toggleSetters[globalName] = function() state = _G[globalName] and true or false; applyVisual(state, false) end

    track.MouseButton1Click:Connect(function()
        state = not state
        _G[globalName] = state
        applyVisual(state, true)
        if callback then callback(state) end
    end)
    return frame
end

local function createDropdown(parent, labelPrefix, list, globalName, callback)
    local function valueOf(item) if type(item) == "table" and item.val ~= nil then return item.val end return item end
    local function labelOf(item) if type(item) == "table" then return tostring(item.label or item.val) end return tostring(item) end

    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, -4, 0, 42)
    frame.BackgroundColor3 = C.panel
    frame.ClipsDescendants = true
    frame.Parent = parent
    uicorner(frame, 8); uistroke(frame, C.stroke)

    local mainBtn = Instance.new("TextButton")
    mainBtn.Size = UDim2.new(1, 0, 0, 42)
    mainBtn.BackgroundTransparency = 1
    mainBtn.TextColor3 = C.textHi
    mainBtn.TextSize = 12
    mainBtn.Font = Enum.Font.GothamBold
    mainBtn.TextXAlignment = Enum.TextXAlignment.Left
    mainBtn.Parent = frame
    local mp = Instance.new("UIPadding"); mp.PaddingLeft = UDim.new(0, 14); mp.Parent = mainBtn

    local indicator = Instance.new("TextLabel")
    indicator.Size = UDim2.new(0, 30, 0, 42); indicator.Position = UDim2.new(1, -34, 0, 0)
    indicator.BackgroundTransparency = 1; indicator.Text = "▼"; indicator.TextColor3 = C.textLo
    indicator.TextSize = 10; indicator.Parent = frame

    local listC = Instance.new("Frame")
    listC.Size = UDim2.new(1, 0, 0, #list * 30); listC.Position = UDim2.new(0, 0, 0, 42)
    listC.BackgroundTransparency = 1; listC.Parent = frame
    local ll = Instance.new("UIListLayout"); ll.Parent = listC

    local function setText(item) mainBtn.Text = labelPrefix .. ":  " .. labelOf(item) end
    local function refreshFromGlobal()
        local target = _G[globalName]
        for _, item in ipairs(list) do if valueOf(item) == target then setText(item); return end end
        setText(list[1])
    end

    for _, item in ipairs(list) do
        local opt = Instance.new("TextButton")
        opt.Size = UDim2.new(1, 0, 0, 30)
        opt.BackgroundColor3 = C.panelAlt
        opt.Text = labelOf(item)
        opt.TextColor3 = C.textLo
        opt.TextSize = 12
        opt.Font = Enum.Font.GothamMedium
        opt.AutoButtonColor = false
        opt.Parent = listC
        opt.MouseEnter:Connect(function() TweenService:Create(opt, TweenInfo.new(0.12), {BackgroundColor3 = Color3.fromRGB(40, 30, 54), TextColor3 = C.textHi}):Play() end)
        opt.MouseLeave:Connect(function() TweenService:Create(opt, TweenInfo.new(0.12), {BackgroundColor3 = C.panelAlt, TextColor3 = C.textLo}):Play() end)
        opt.MouseButton1Click:Connect(function()
            _G[globalName] = valueOf(item)
            setText(item)
            indicator.Text = "▼"
            frame.ZIndex = 1
            TweenService:Create(frame, TweenInfo.new(0.18, Enum.EasingStyle.Quad), {Size = UDim2.new(1, -4, 0, 42)}):Play()
            if callback then callback(item) end
        end)
    end

    local isOpen = false
    mainBtn.MouseButton1Click:Connect(function()
        isOpen = not isOpen
        indicator.Text = isOpen and "▲" or "▼"
        frame.ZIndex = isOpen and 5 or 1
        TweenService:Create(frame, TweenInfo.new(0.18, Enum.EasingStyle.Quad), {Size = UDim2.new(1, -4, 0, isOpen and (42 + #list * 30) or 42)}):Play()
    end)

    refreshFromGlobal()
    if globalName then dropdownRefreshers[globalName] = refreshFromGlobal end
    return frame
end

