local ROOT_FOLDER     = "DBP_Scripts"
local CONFIG_FOLDER   = ROOT_FOLDER .. "/configs"
local DATA_FOLDER     = ROOT_FOLDER .. "/data"
local LAST_CONFIG_PTR = DATA_FOLDER .. "/last_config.txt"
local LEGACY_FILE     = "evomon_premium_config.json"

local function ensureFolders()
    pcall(function()
        if not makefolder then return end
        if not (isfolder and isfolder(ROOT_FOLDER))   then makefolder(ROOT_FOLDER) end
        if not (isfolder and isfolder(CONFIG_FOLDER)) then makefolder(CONFIG_FOLDER) end
        if not (isfolder and isfolder(DATA_FOLDER))   then makefolder(DATA_FOLDER) end
    end)
end

local function configPath(name) return CONFIG_FOLDER .. "/" .. name .. ".json" end

local function sanitizeName(name)
    if type(name) ~= "string" then return nil end
    name = name:gsub("^%s+", ""):gsub("%s+$", "")
    name = name:gsub("[^%w%-_ ]", "")
    if name == "" then return nil end
    return name
end

local function buildConfigTable()
    return {
        farmEnabled     = _G.EvomonFarmEnabled,
        speedupEnabled  = _G.EvomonSpeedupEnabled,
        autoCatch       = _G.EvomonAutoCatch,
        autoCatchShiny  = _G.EvomonAutoCatchShiny,
        autoSellEnabled = _G.EvomonAutoSellEnabled,
        autoHatch       = _G.EvomonAutoHatch,
        onlyCatchShiny  = _G.EvomonOnlyCatchShinyPrismatic,
        safeCheckMode   = _G.EvomonSafeCheckMode,
        pityWatcher     = _G.EvomonPityWatcherEnabled,
        normalBall      = _G.EvomonNormalBall,
        shinyBall       = _G.EvomonShinyBall,
        prismaticBall   = _G.EvomonPrismaticBall,
        minSellGrade    = _G.EvomonMinSellGrade,
        farmRadius      = _G.EvomonFarmRadius,
        autoInGameSpeed = _G.EvomonAutoInGameSpeed,
        autoInGameAuto  = _G.EvomonAutoInGameAutoBattle,
        hideKeybind     = _G.EvomonHideKeybind and _G.EvomonHideKeybind.Name or "RightAlt",
        bossFarmEnabled = _G.EvomonBossFarmEnabled,
    }
end

local function applyConfigTable(config)
    if type(config) ~= "table" then return end
    local function set(key, global) if config[key] ~= nil then _G[global] = config[key] end end
    set("farmEnabled",     "EvomonFarmEnabled")
    set("speedupEnabled",  "EvomonSpeedupEnabled")
    set("autoCatch",       "EvomonAutoCatch")
    set("autoCatchShiny",  "EvomonAutoCatchShiny")
    set("autoSellEnabled", "EvomonAutoSellEnabled")
    set("autoHatch",       "EvomonAutoHatch")
    set("onlyCatchShiny",  "EvomonOnlyCatchShinyPrismatic")
    set("safeCheckMode",   "EvomonSafeCheckMode")
    set("pityWatcher",     "EvomonPityWatcherEnabled")
    set("normalBall",      "EvomonNormalBall")
    set("shinyBall",       "EvomonShinyBall")
    set("prismaticBall",   "EvomonPrismaticBall")
    set("minSellGrade",    "EvomonMinSellGrade")
    set("farmRadius",      "EvomonFarmRadius")
    set("autoInGameSpeed", "EvomonAutoInGameSpeed")
    set("autoInGameAuto",  "EvomonAutoInGameAutoBattle")
    set("bossFarmEnabled", "EvomonBossFarmEnabled")
    if config.hideKeybind ~= nil then
        _G.EvomonHideKeybind = Enum.KeyCode[config.hideKeybind] or Enum.KeyCode.RightAlt
    end
end

local function listConfigs()
    ensureFolders()
    local names = {}
    pcall(function()
        if not listfiles then return end
        for _, path in ipairs(listfiles(CONFIG_FOLDER)) do
            local fname = path:match("([^/\\]+)%.json$")
            if fname then table.insert(names, fname) end
        end
    end)
    table.sort(names)
    return names
end

local function saveConfigAs(name)
    name = sanitizeName(name)
    if not name then return false, "invalid name" end
    ensureFolders()
    local ok = pcall(function()
        if writefile then
            writefile(configPath(name), HttpService:JSONEncode(buildConfigTable()))
            writefile(LAST_CONFIG_PTR, name)
        end
    end)
    return ok, name
end

local function loadConfigByName(name)
    name = sanitizeName(name)
    if not name or not (isfile and isfile(configPath(name))) then return false end
    local ok = pcall(function()
        applyConfigTable(HttpService:JSONDecode(readfile(configPath(name))))
        if writefile then writefile(LAST_CONFIG_PTR, name) end
    end)
    return ok, name
end

local function deleteConfigByName(name)
    name = sanitizeName(name)
    if not name then return false end
    local ok = pcall(function()
        if delfile and isfile and isfile(configPath(name)) then delfile(configPath(name)) end
    end)
    return ok
end

local function getLastConfigName()
    local n
    pcall(function()
        if isfile and isfile(LAST_CONFIG_PTR) then n = sanitizeName(readfile(LAST_CONFIG_PTR)) end
    end)
    return n
end

local function migrateLegacy()
    pcall(function()
        if isfile and isfile(LEGACY_FILE) and #listConfigs() == 0 then
            local data = HttpService:JSONDecode(readfile(LEGACY_FILE))
            applyConfigTable(data)
            saveConfigAs("Default")
        end
    end)
end

