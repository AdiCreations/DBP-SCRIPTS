-- PITY WATCHER
local PityWatcher = { currentPity=0, lastPity=0, cachedTable=nil, scanAttempts=0, maxScanAttempts=8 }
function PityWatcher:CheckPity()
    if not _G.EvomonPityWatcherEnabled then return false end
    local triggered = false
    pcall(function()
        if self.cachedTable and typeof(self.cachedTable) == "table" then
            local pVal = rawget(self.cachedTable, "_shinyPity") or rawget(self.cachedTable, "pityVal") or rawget(self.cachedTable, "shinyPity")
            if typeof(pVal) == "number" then
                self.currentPity = pVal
                if self.lastPity > 0 and self.currentPity == 0 then triggered = true end
                self.lastPity = self.currentPity; return
            end
        end
        if self.scanAttempts >= self.maxScanAttempts then return end
        self.scanAttempts = self.scanAttempts + 1
        for _, v in pairs(getgc(true)) do
            if typeof(v) == "table" then
                local pVal = rawget(v, "_shinyPity") or rawget(v, "pityVal") or rawget(v, "shinyPity")
                if typeof(pVal) == "number" then
                    self.cachedTable = v; self.currentPity = pVal
                    if self.lastPity > 0 and self.currentPity == 0 then triggered = true end
                    self.lastPity = self.currentPity; break
                end
            end
        end
    end)
    return triggered
end

